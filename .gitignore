.env
.env.*
!.env.example

# ------------------------------
# Python: Байт-код и виртуальные окружения
# ------------------------------
__pycache__/
*.py[cod]
*.so
.Python

# Виртуальные окружения (стандартные и для uv)
.venv/
venv/
env/
ENV/

# ------------------------------
# Современные инструменты (Astral: uv, ruff)
# ------------------------------
# Кэш и артефакты uv (менеджера пакетов)
.uv/

# Кэш Ruff (линтера и форматтера)
.ruff_cache/

# Кэш типизации
.mypy_cache/
.ty/          # Кэш для Ty (type-checker от Astral)

# ------------------------------
# Управление пакетами и сборка
# ------------------------------
# Poetry
poetry.lock   # Рекомендуется коммитить для приложений, для библиотек — игнорировать

# Базовые артефакты сборки
build/
dist/
*.egg-info/
*.egg

# ------------------------------
# Тестирование и покрытие кода
# ------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# ------------------------------
# IDE и редакторы
# ------------------------------
# PyCharm
.idea/
*.iml

# VS Code
.vscode/
*.code-workspace

# ------------------------------
# Операционные системы
# ------------------------------
# macOS
.DS_Store
.AppleDouble

# Windows
Thumbs.db

# ------------------------------
# Данные (если они большие или генерируемые)
# ------------------------------
# Тяжелые данные можно игнорировать, но при необходимости разрешить отдельные файлы.
data/
*.csv
*.parquet
# !data/small-etl-example.csv    # Как разрешить конкретный файл

# ------------------------------
# Логи и временные файлы
# ------------------------------
*.log
*.tmp
*.bak